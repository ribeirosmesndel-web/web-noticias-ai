RewriteEngine On

# Allow access to API and Admin normally
RewriteCond %{REQUEST_URI} ^/admin/ [OR]
RewriteCond %{REQUEST_URI} ^/api/ [OR]
RewriteCond %{REQUEST_URI} ^/install/ [OR]
RewriteCond %{REQUEST_URI} ^/assets/
RewriteRule ^ - [L]

# Prevent directory listing
Options -Indexes

# Rewrite Categories (e.g., /tecnologia)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9-]+)/?$ category.php?slug=$1 [L,QSA]

# Rewrite Articles (e.g., /tecnologia/novo-iphone-15)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/?$ article.php?slug=$2 [L,QSA]
